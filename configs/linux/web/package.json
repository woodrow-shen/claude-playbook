{
  "name": "kernel-quest",
  "version": "0.1.0",
  "description": "Gamified Linux kernel learning skill tree",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build-data && npm run build-snippets && vite build",
    "build-data": "tsx scripts/build-skill-data.ts",
    "build-snippets": "tsx scripts/build-srcref-snippets.ts",
    "sync-paths-docs": "tsx scripts/sync-paths-docs.ts",
    "validate": "tsx scripts/validate-skills.ts && tsx scripts/sync-paths-docs.ts --check",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^29.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "js-yaml": "^4.1.0",
    "marked": "^12.0.0"
  }
}
